---
const scenarios = [
  {
    title: 'Make work apps less painful',
    body: 'Tune internal dashboards, admin panels, and docs tools so they are easier to scan.',
    command: 'restyle dashboard.local',
  },
  {
    title: 'Build personal themes',
    body: 'Save CSS for sites you use every day and switch between variants with palettes.',
    command: 'toggle Gmail dark theme',
  },
  {
    title: 'Keep temporary fixes around',
    body: 'Archive old rules instead of deleting CSS you may need again later.',
    command: 'restore archived rule',
  },
];
---

<div class="divide-y divide-border rounded-lg border border-border bg-card">
  {
    scenarios.map((scenario, index) => (
      <section class="grid gap-3 p-5 md:grid-cols-[4rem_1fr_auto] md:items-center">
        <span class="text-lg font-semibold text-primary">{String(index + 1).padStart(2, '0')}.</span>
        <div class="flex flex-col gap-1">
          <h3 class="text-lg font-semibold text-card-foreground">{scenario.title}</h3>
          <p class="text-sm leading-relaxed text-muted-foreground">{scenario.body}</p>
        </div>
        <code class="w-fit rounded-md bg-muted px-2.5 py-1.5 text-xs text-muted-foreground">{scenario.command}</code>
      </section>
    ))
  }
</div>
