---
import { LinkCard } from '@astrojs/starlight/components';

interface Props {
  title: string;
  href: string;
  description?: string;
  external?: boolean;
  rel?: string;
}

const { title, href, description, external = false, rel } = Astro.props;
---

<div
  class="chameleon-link-card"
  class:list={[
    '[&_.sl-link-card]:rounded-lg [&_.sl-link-card]:border-border [&_.sl-link-card]:bg-card',
    '[&_.sl-link-card]:transition-[background-color,border-color,box-shadow] [&_.sl-link-card]:duration-200 [&_.sl-link-card]:ease-in-out',
    '[&_.sl-link-card:hover]:border-primary [&_.sl-link-card:hover]:shadow-md',
    '[&_.sl-link-card_.title]:text-card-foreground [&_.sl-link-card_.description]:text-muted-foreground [&_.sl-link-card_.icon]:text-primary',
  ]}
>
  <LinkCard
    title={title}
    href={href}
    description={description}
    target={external ? '_blank' : undefined}
    rel={rel ?? (external ? 'noreferrer' : undefined)}
  />
</div>

<style>
  .chameleon-link-card :global(.sl-link-card) {
    align-items: start;
  }

  .chameleon-link-card :global(.sl-link-card:hover),
  .chameleon-link-card :global(.sl-link-card:focus-within) {
    background-color: color-mix(in oklch, var(--chameleon-primary) 14%, var(--chameleon-card));
    border-color: var(--chameleon-primary);
  }

  .chameleon-link-card :global(.sl-link-card .title) {
    text-decoration-line: underline;
    text-decoration-style: dashed;
    text-decoration-color: color-mix(in oklch, var(--chameleon-primary) 60%, transparent);
    text-decoration-thickness: 2px;
    text-underline-offset: 0.18em;
    transition: text-decoration-color 200ms ease-in-out;
  }

  .chameleon-link-card :global(.sl-link-card:hover .title),
  .chameleon-link-card :global(.sl-link-card:focus-within .title) {
    text-decoration-style: solid;
    text-decoration-color: var(--chameleon-primary);
  }

  .chameleon-link-card :global(.sl-link-card .icon) {
    margin-block-start: 0.15rem;
    color: var(--chameleon-primary);
  }

  .chameleon-link-card :global(.sl-link-card:has(a[rel='prev']) .icon) {
    transform: rotate(180deg);
  }

  .chameleon-link-card :global(.sl-link-card:hover .icon),
  .chameleon-link-card :global(.sl-link-card:focus-within .icon) {
    color: var(--chameleon-primary);
  }
</style>
